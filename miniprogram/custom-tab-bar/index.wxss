/* miniprogram/custom-tab-bar/index.wxss */
.tab-bar {
  display: flex;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
  color: #999;
  font-size: 24rpx;
}

.tab-item.active {
  color: #667eea;
}

.tab-item .icon-text {
  font-size: 40rpx;
  margin-bottom: 4rpx;
  line-height: 1;
}

.tab-item .text {
  font-size: 24rpx;
  line-height: 1;
}
