/* pages/rentals/pay.wxss */
page {
 background: #f5f7fa; 
}
.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 padding: 30rpx;
}

.form {
 background: white; border-radius: 16rpx; padding: 30rpx; 
}

.form-item {
 margin-bottom: 30rpx; 
}
.label {
 display: block; font-size: 28rpx; color: #333; margin-bottom: 10rpx; font-weight: 500; 
}

.picker {
 
  background: #f5f5f5; 
  padding: 20rpx; 
  border-radius: 8rpx; 
  font-size: 28rpx;
  color: #333;

}

.input {
 
  background: #f5f5f5; 
  padding: 20rpx; 
  border-radius: 8rpx; 
  font-size: 28rpx;

}

.textarea {

  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  width: 100%;
  height: 150rpx;
  box-sizing: border-box;

}

.submit-btn {

  background: linear-gradient(135deg, #667eea, #764ba2);
  color: white;
  border-radius: 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  margin-top: 40rpx;

}
