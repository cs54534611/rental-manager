<!-- miniprogram/pages/rentals/list.wxml -->
<view class="container">
  <!-- 筛选 -->
  <view class="filter-bar">
    <view class="filter-item {{status===''?'active':''}}" bindtap="onFilter" data-status="">全部</view>
    <view class="filter-item {{status===0?'active':''}}" bindtap="onFilter" data-status="0">未付</view>
    <view class="filter-item {{status===1?'active':''}}" bindtap="onFilter" data-status="1">已付</view>
    <view class="filter-item {{status===2?'active':''}}" bindtap="onFilter" data-status="2">逾期</view>
  </view>

  <!-- 统计 -->
  <view class="stats-card">
    <view class="stat">
      <text class="label">待收金额</text>
      <text class="value warning">¥{{pendingAmount}}</text>
    </view>
    <view class="stat">
      <text class="label">待付笔数</text>
      <text class="value">{{pendingCount}}</text>
    </view>
  </view>

  <!-- 列表 -->
  <scroll-view scroll-y class="list">
    <view class="item" wx:for="{{rentals}}" wx:key="id">
      <view class="item-header">
        <text class="period">{{item.period}}</text>
        <text class="status {{item.status}}">{{statusMap[item.status]}}</text>
      </view>
      <view class="item-body">
        <text class="address">{{item.community}} - {{item.address}}</text>
        <text class="tenant">{{item.tenant_name}}</text>
      </view>
      <view class="item-footer">
        <view class="money">
          <text class="receivable">应收: ¥{{item.receivable}}</text>
          <text class="actual" wx:if="{{item.status===1}}">实收: ¥{{item.actual}}</text>
        </view>
        <view class="actions">
          <view class="edit" wx:if="{{item.status===0}}" bindtap="onPay" data-id="{{item.id}}">记收</view>
          <view class="delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>

    <view wx:if="{{rentals.length===0}}" class="empty">暂无账单</view>
  </scroll-view>

  <view class="add-btn" bindtap="goToAdd">➕ 记收租金</view>
</view>
