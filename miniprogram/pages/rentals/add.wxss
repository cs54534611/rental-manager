/* miniprogram/pages/rentals/add.wxss */
page {
 background: #f5f7fa; 
}
.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 padding: 30rpx;
}

.form-section {

  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;

}

.form-title {

  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;

}

.form-item {

  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;

}
.form-item:last-child {
 border-bottom: none; 
}

.label {
 width: 180rpx; font-size: 28rpx; color: #333; 
}
.input {
 flex: 1; font-size: 28rpx; text-align: right; 
}

.picker {

  flex: 1;
  font-size: 28rpx;
  text-align: right;
  color: #333;

}

.contract-info {

  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;

}
.contract-info .rent {
 color: #667eea; font-weight: 600; 
}

.textarea {

  width: 100%;
  height: 150rpx;
  font-size: 28rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 20rpx;

}

.submit-btn {

  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 44rpx;
  color: white;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;

}
