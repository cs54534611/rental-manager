.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 30rpx;
}
.section { margin-bottom: 40rpx; }
.section-title { font-size: 30rpx; font-weight: bold; margin-bottom: 20rpx; }
.type-list {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
}
.type-item {
  padding: 20rpx 30rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.type-item.active { background: #667eea; color: white; }
.textarea {
  width: 100%;
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.char-count { text-align: right; font-size: 24rpx; color: #999; margin-top: 10rpx; }
.submit-btn {
  background: #667eea;
  color: white;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
}
