.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 30rpx;
  padding-bottom: 120rpx;
}
.list {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}
.type-tag {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}
.type-tag.complaint { background: #ffebee; color: #e53935; }
.type-tag.suggestion { background: #e3f2fd; color: #1976d2; }
.type-tag.praise { background: #e8f5e9; color: #2e7d32; }
.status-tag { padding: 6rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; }
.card-body { font-size: 28rpx; line-height: 1.6; margin-bottom: 20rpx; }
.card-meta { font-size: 24rpx; color: #999; display: flex; justify-content: space-between; }
.card-reply {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}
.reply-label { color: #667eea; font-weight: bold; }
.card-actions { margin-top: 20rpx; display: flex; justify-content: flex-end; }
.btn-reply {
  background: #667eea;
  color: white;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 8rpx;
}
.empty { text-align: center; color: #999; padding: 100rpx; font-size: 28rpx; }
.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #667eea;
  color: white;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(102,126,234,0.4);
}