/* miniprogram/pages/contracts/detail.wxss */
page { background: #f5f7fa; }
.container { padding: 20rpx; padding-bottom: 150rpx; }

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.no { font-size: 32rpx; font-weight: 600; color: #333; }

.status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}
.status[status="1"] { background: #d1fae5; color: #059669; }
.status[status="0"] { background: #f3f4f6; color: #6b7280; }

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child { border-bottom: none; }
.info-row .label { font-size: 26rpx; color: #999; }
.info-row .value { font-size: 26rpx; color: #333; }
.info-row .value.primary { color: #667eea; font-weight: 600; }

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn {
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex: 1;
}

.btn.primary { background: #667eea; color: white; margin-right: 20rpx; }
.btn.terminate { background: #fee2e2; color: #dc2626; }
