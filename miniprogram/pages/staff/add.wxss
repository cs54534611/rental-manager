/* miniprogram/pages/staff/add.wxss */
page {
 background: #f5f7fa; 
}
.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 padding: 30rpx;
}

.form {

  background: white;
  border-radius: 16rpx;
  padding: 30rpx;

}

.form-item {

  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;

}

.form-item:last-of-type {
 border-bottom: none; 
}

.label {
 width: 120rpx; font-size: 28rpx; color: #333; 
}
.input {
 flex: 1; font-size: 28rpx; 
}

.textarea {

  width: 100%;
  height: 150rpx;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx;
  font-size: 28rpx;
  margin-top: 10rpx;

}

.submit-btn {

  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 44rpx;
  color: white;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;

}
