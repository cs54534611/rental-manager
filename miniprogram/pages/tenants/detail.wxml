<!-- miniprogram/pages/tenants/detail.wxml -->
<view class="container">
  <view class="profile-card">
    <view class="avatar">{{tenant.name[0]}}</view>
    <view class="info">
      <text class="name">{{tenant.name}}</text>
      <text class="gender">{{tenant.gender===1?'男':'女'}}</text>
    </view>
    <text class="status {{tenant.status}}">{{tenant.status===1?'正常':'拉黑'}}</text>
  </view>

  <view class="card">
    <view class="card-title">联系方式</view>
    <view class="info-row">
      <text class="label">手机号</text>
      <text class="value">{{tenant.phone}}</text>
    </view>
    <view class="info-row" wx:if="{{tenant.id_card}}">
      <text class="label">身份证</text>
      <text class="value">{{tenant.id_card}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{tenant.emergency_contact}}">
    <view class="card-title">紧急联系人</view>
    <view class="info-row">
      <text class="label">姓名</text>
      <text class="value">{{tenant.emergency_contact}}</text>
    </view>
    <view class="info-row" wx:if="{{tenant.emergency_phone}}">
      <text class="label">电话</text>
      <text class="value">{{tenant.emergency_phone}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{tenant.remark}}">
    <view class="card-title">备注</view>
    <text class="remark">{{tenant.remark}}</text>
  </view>

  <view class="action-bar">
    <view class="btn edit" bindtap="onEdit">编辑</view>
    <view class="btn delete" bindtap="onDelete">删除</view>
  </view>
</view>
