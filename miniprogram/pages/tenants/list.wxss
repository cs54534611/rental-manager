/* miniprogram/pages/tenants/list.wxss */
page { background: #f5f7fa; }
.container { padding: 20rpx; }

.search-bar {
  display: flex;
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}
.search-bar input { flex: 1; font-size: 28rpx; }
.search-btn { color: #667eea; font-size: 28rpx; padding-left: 20rpx; }

.list { height: calc(100vh - 200rpx); }

.item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.info { flex: 1; }
.name-row { display: flex; align-items: center; gap: 10rpx; }
.name { font-size: 30rpx; font-weight: 600; color: #333; }
.gender { font-size: 24rpx; color: #999; background: #f5f5f5; padding: 2rpx 10rpx; border-radius: 4rpx; }
.phone { font-size: 26rpx; color: #666; margin-top: 8rpx; }
.id-card { font-size: 24rpx; color: #999; margin-top: 6rpx; }

.status { font-size: 24rpx; padding: 6rpx 16rpx; border-radius: 6rpx; }
.status[status="1"] { background: #d1fae5; color: #059669; }
.status[status="0"] { background: #fee2e2; color: #dc2626; }

.right-actions { display: flex; align-items: center; gap: 16rpx; }
.delete-btn, .delete { 
  font-size: 24rpx; 
  color: #fff; 
  background: #ef4444; 
  padding: 8rpx 20rpx; 
  border-radius: 8rpx; 
}

.empty { text-align: center; padding: 100rpx; color: #999; }

.add-btn {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 40rpx;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
