<!--pages/checkout/detail.wxml-->
<view class="container">
  <view class="header">
    <text class="title">退房详情</text>
  </view>

  <view class="card">
    <view class="row">
      <text class="label">合同编号</text>
      <text class="value">{{detail.contract_no}}</text>
    </view>
    <view class="row">
      <text class="label">房源</text>
      <text class="value">{{detail.address}}</text>
    </view>
    <view class="row">
      <text class="label">租客</text>
      <text class="value">{{detail.tenant_name}}</text>
    </view>
    <view class="row">
      <text class="label">申请时间</text>
      <text class="value">{{detail.apply_date}}</text>
    </view>
    <view class="row">
      <text class="label">状态</text>
      <text class="value status{{detail.status}}">{{statusText}}</text>
    </view>
  </view>

  <view class="card">
    <view class="row">
      <text class="label">应收押金</text>
      <text class="value">¥{{detail.deposit_expected}}</text>
    </view>
    <view class="row">
      <text class="label">扣款</text>
      <text class="value danger">¥{{detail.deposit_deduct}}</text>
    </view>
    <view class="row">
      <text class="label">扣款原因</text>
      <text class="value">{{detail.deduct_reason}}</text>
    </view>
    <view class="row">
      <text class="label">应退押金</text>
      <text class="value success">¥{{detail.deposit_refund}}</text>
    </view>
  </view>

  <view class="card" wx:if="{{detail.remark}}">
    <view class="row">
      <text class="label">备注</text>
      <text class="value">{{detail.remark}}</text>
    </view>
  </view>

  <view class="actions" wx:if="{{detail.status == 0}}">
    <button class="btn-primary" bindtap="handlePass">通过</button>
    <button class="btn-danger" bindtap="handleReject">拒绝</button>
  </view>
</view>
