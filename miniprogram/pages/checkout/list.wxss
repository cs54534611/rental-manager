/* miniprogram/pages/checkout/list.wxss */
.container {

  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;

}

.filter {

  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;

}

.picker {

  display: inline-block;
  padding: 10rpx 30rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #333;

}

.arrow {

  margin-left: 10rpx;
  color: #999;
  font-size: 20rpx;

}

.checkout-list {

  padding: 20rpx;

}

.checkout-item {

  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;

}

.checkout-header {

  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-bottom: 1rpx solid #eee;

}

.contract-no {

  font-size: 28rpx;
  color: #333;
  font-weight: bold;

}

.status {

  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;

}

.status.0 {

  background: #fff3e0;
  color: #ff9800;

}

.status.1 {

  background: #e3f2fd;
  color: #2196f3;

}

.status.2 {

  background: #e8f5e9;
  color: #4caf50;

}

.status.3 {

  background: #f5f5f5;
  color: #999;

}

.checkout-body {

  padding: 20rpx;

}

.info-row {

  display: flex;
  margin-bottom: 10rpx;

}

.info-row .label {

  font-size: 26rpx;
  color: #999;
  width: 160rpx;

}

.info-row .value {

  font-size: 26rpx;
  color: #333;
  flex: 1;

}

.checkout-footer {

  padding: 20rpx;
  border-top: 1rpx solid #eee;
  text-align: right;

}

.refund {

  font-size: 32rpx;
  font-weight: bold;
  color: #4caf50;

}

.empty {

  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;

}

.add-btn {

  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);

}

.add-btn text {

  font-size: 60rpx;
  color: #fff;
  font-weight: bold;

}
