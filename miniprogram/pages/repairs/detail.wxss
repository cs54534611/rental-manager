/* miniprogram/pages/repairs/detail.wxss */
page { background: #f5f7fa; }
.container { padding: 20rpx; padding-bottom: 150rpx; }

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.no { font-size: 32rpx; font-weight: 600; color: #333; }

.urgency {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}
.urgency[urgency="1"] { background: #e0f2fe; color: #0284c7; }
.urgency[urgency="2"] { background: #fef3c7; color: #d97706; }
.urgency[urgency="3"] { background: #fee2e2; color: #dc2626; }

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.info-row:last-child { border-bottom: none; }
.info-row .label { font-size: 26rpx; color: #999; }
.info-row .value { font-size: 26rpx; color: #333; }
.info-row .value.primary { color: #667eea; font-weight: 600; }

.status-tag {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}
.status-tag[status="0"] { background: #fee2e2; color: #dc2626; }
.status-tag[status="1"], .status-tag[status="2"], .status-tag[status="3"] { background: #fef3c7; color: #d97706; }
.status-tag[status="4"] { background: #e0f2fe; color: #0284c7; }
.status-tag[status="5"], .status-tag[status="6"] { background: #d1fae5; color: #059669; }

.description {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn {
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.btn.primary { background: #667eea; color: white; }

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.photo-grid image {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
}

.picker-btn {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  color: #667eea;
  font-size: 28rpx;
}
