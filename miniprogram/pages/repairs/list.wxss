/* miniprogram/pages/repairs/list.wxss */
page {
 background: #f5f7fa; 
}
.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 padding: 20rpx;
}

.filter-bar {

  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;

}
.filter-item {

  padding: 10rpx 30rpx;
  background: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;

}
.filter-item.active {

  background: #667eea;
  color: white;

}

.list {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 height: calc(100vh - 300rpx);
}

.item {

  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;

}

.item-header {

  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;

}
.no {
 font-size: 28rpx; font-weight: 600; color: #333; 
}
.urgency {
 font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 6rpx; 
}
.urgency[urgency="1"] {
 background: #e0f2fe; color: #0284c7; 
}
.urgency[urgency="2"] {
 background: #fef3c7; color: #d97706; 
}
.urgency[urgency="3"] {
 background: #fee2e2; color: #dc2626; 
}

.item-body {

  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;

}
.address {
 font-size: 26rpx; color: #333; 
}
.type {
 font-size: 24rpx; color: #667eea; 
}

.item-desc {

  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;

}

.item-footer {

  display: flex;
  justify-content: space-between;

}
.date {
 font-size: 24rpx; color: #999; 
}
.footer-right {
 display: flex; align-items: center; gap: 16rpx; 
}
.status {
 font-size: 24rpx; padding: 4rpx 12rpx; border-radius: 6rpx; 
}
.status[status="0"] {
 background: #fee2e2; color: #dc2626; 
}
.status[status="1"], .status[status="2"], .status[status="3"] {
 background: #fef3c7; color: #d97706; 
}
.status[status="4"] {
 background: #e0f2fe; color: #0284c7; 
}
.status[status="5"], .status[status="6"] {
 background: #d1fae5; color: #059669; 
}
.delete {
 
  font-size: 24rpx; 
  color: #fff; 
  background: #ef4444; 
  padding: 8rpx 20rpx; 
  border-radius: 8rpx; 

}
.edit {
 
  font-size: 24rpx; 
  color: #fff; 
  background: #3b82f6; 
  padding: 8rpx 20rpx; 
  border-radius: 8rpx; 

}

.empty {
 text-align: center; padding: 100rpx; color: #999; 
}

.add-btn {

  position: fixed;
  bottom: 160rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 300rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 40rpx;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(102, 126, 234, 0.4);
  z-index: 100;

}
