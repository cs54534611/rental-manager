/* miniprogram/pages/payments/list.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.filter {
  background: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.picker {
  display: inline-block;
  padding: 10rpx 30rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #333;
}

.arrow {
  margin-left: 10rpx;
  color: #999;
  font-size: 20rpx;
}

.payment-list {
  padding: 20rpx;
}

.payment-item {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.payment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-bottom: 1rpx solid #eee;
}

.payment-no {
  font-size: 24rpx;
  color: #999;
}

.payment-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.payment-status.pending {
  background: #fff3e0;
  color: #ff9800;
}

.payment-status.success {
  background: #e8f5e9;
  color: #4caf50;
}

.payment-status.failed {
  background: #ffebee;
  color: #f44336;
}

.payment-status.refunded {
  background: #e3f2fd;
  color: #2196f3;
}

.payment-body {
  padding: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
}

.info-row .label {
  font-size: 26rpx;
  color: #999;
  width: 160rpx;
}

.info-row .value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
}

.payment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-top: 1rpx solid #eee;
}

.amount {
  font-size: 36rpx;
  font-weight: bold;
  color: #f44336;
}

.btn-refund {
  background: #fff;
  color: #999;
  border: 1rpx solid #ddd;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}
