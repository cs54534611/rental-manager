<view class="container">
  <view class="header">
    <text class="role-label">当前角色</text>
    <text class="role-name">{{roleName}}</text>
  </view>

  <view class="desc">
    <text>您当前角色可访问以下功能：</text>
  </view>

  <view class="menu-grid">
    <view class="menu-item" wx:for="{{menuItems}}" wx:key="key" data-url="{{item.url}}" bindtap="navigateTo">
      <view class="menu-icon">{{item.icon}}</view>
      <text class="menu-name">{{item.name}}</text>
    </view>
  </view>
</view>
