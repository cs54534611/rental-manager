/* miniprogram/pages/backup/index.wxss */
page {
 background: #f5f7fa; 
}
.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 padding: 30rpx;
}

.section {

  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;

}

.section-title {

  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;

}

.info-card {

  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;

}

.info-row {

  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;

}

.info-row .label {
 color: #666; font-size: 26rpx; 
}
.info-row .value {
 color: #333; font-size: 26rpx; 
}

.btn {

  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;

}

.btn.primary {
 background: #667eea; color: white; 
}

.list {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
 margin-top: 10rpx;
}

.item {

  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;

}

.item:last-child {
 border-bottom: none; 
}

.item .info {
 flex: 1; 
}
.item .name {
 font-size: 26rpx; color: #333; display: block; 
}
.item .size {
 font-size: 24rpx; color: #999; 
}

.actions {
 display: flex; gap: 20rpx; 
}

.btn-restore {
 color: #667eea; font-size: 26rpx; 
}
.btn-delete {
 color: #dc2626; font-size: 26rpx; 
}

.empty {
 text-align: center; padding: 60rpx; color: #999; 
}
