/* miniprogram/pages/houses/detail.wxss */
page { background: #f5f7fa; }
.container { padding-bottom: 150rpx; }

.swiper { height: 400rpx; }
.slide-image { width: 100%; height: 100%; }
.no-photo {
  width: 100%;
  height: 100%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.no-photo text { color: #999; font-size: 28rpx; }

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.address { font-size: 32rpx; font-weight: 600; color: #333; }

.status {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}
.status[status="0"] { background: #fee2e2; color: #dc2626; }
.status[status="1"] { background: #d1fae5; color: #059669; }
.status[status="2"] { background: #fef3c7; color: #d97706; }

.tags { display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 20rpx; }
.tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  color: #666;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.info-item { text-align: center; }
.info-item .label { display: block; font-size: 24rpx; color: #999; margin-bottom: 8rpx; }
.info-item .value { font-size: 28rpx; color: #333; }
.info-item .value.primary { color: #667eea; font-weight: 600; }

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.facilities { display: flex; flex-wrap: wrap; gap: 16rpx; }
.facility {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background: #f5f5f5;
  border-radius: 6rpx;
  color: #666;
}

.remark { font-size: 26rpx; color: #666; line-height: 1.6; }

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  padding: 20rpx;
  gap: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.btn.edit { background: #667eea; color: white; }
.btn.primary { background: #34D399; color: white; }
.btn.delete { background: #fee2e2; color: #dc2626; }
