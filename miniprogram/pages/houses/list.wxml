<!-- miniprogram/pages/houses/list.wxml -->
<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <input placeholder="搜索小区/地址/房源编号" bindinput="onSearch" />
    <view class="search-btn">搜索</view>
  </view>

  <!-- 筛选 -->
  <view class="filter-bar">
    <view class="filter-item {{status===''?'active':''}}" bindtap="onFilter" data-status="">全部</view>
    <view class="filter-item {{status===0?'active':''}}" bindtap="onFilter" data-status="0">空置</view>
    <view class="filter-item {{status===1?'active':''}}" bindtap="onFilter" data-status="1">已出租</view>
    <view class="filter-item {{status===2?'active':''}}" bindtap="onFilter" data-status="2">待出租</view>
  </view>

  <!-- 房源列表 -->
  <scroll-view scroll-y class="house-list">
    <view class="house-item" wx:for="{{houses}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="house-img" src="{{item.photos[0] || '/images/house-default.png'}}" mode="aspectFill" />
      <view class="house-info">
        <view class="house-header">
          <text class="house-address">{{item.community}} - {{item.address}}</text>
          <text class="house-status {{item.status}}">{{statusMap[item.status]}}</text>
        </view>
        <view class="house-detail">
          <text>{{item.layout}}</text>
          <text>{{item.area}}㎡</text>
          <text>{{item.orientation}}</text>
        </view>
        <view class="house-footer">
          <text class="house-rent">¥{{item.rent}}/月</text>
          <text class="house-floor">{{item.floor}}层</text>
        </view>
      </view>
    </view>

    <view wx:if="{{houses.length === 0}}" class="empty">
      <text>暂无房源</text>
    </view>
  </scroll-view>

  <!-- 添加按钮 -->
  <view class="add-btn" bindtap="goToAdd">➕ 添加房源</view>
</view>
