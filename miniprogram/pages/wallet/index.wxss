.balance-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 40rpx;
  border-radius: 20rpx;
  margin: 30rpx;
  text-align: center;
}
.balance-label { font-size: 28rpx; opacity: 0.8; }
.balance-amount { font-size: 72rpx; font-weight: bold; margin: 20rpx 0; }
.balance-hint { font-size: 24rpx; opacity: 0.7; }
.action-row {
  display: flex;
  padding: 0 30rpx;
  gap: 20rpx;
  margin-bottom: 40rpx;
}
.action-btn {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.action-btn .icon { font-size: 48rpx; }
.action-btn.primary { background: #667eea; color: white; }
.action-btn.active { background: #e8f5e9; color: #2e7d32; }
.section-title {
  padding: 0 30rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.history-list {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  padding: 0 30rpx;
}
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.history-left .history-type { font-size: 28rpx; margin-bottom: 8rpx; }
.history-date { font-size: 24rpx; color: #999; }
.history-right { font-size: 32rpx; font-weight: bold; }
.history-right.income { color: #2e7d32; }
.history-right.expense { color: #e53935; }
.text-green { color: #2e7d32; }
.text-red { color: #e53935; }
.text-blue { color: #1976d2; }
.empty { text-align: center; color: #999; padding: 60rpx; font-size: 28rpx; }
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}
.modal-content {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 600rpx;
}
.modal-title { font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; }
.modal-input {
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
}
.modal-btns { display: flex; gap: 20rpx; }
.btn-cancel, .btn-confirm {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}
.btn-cancel { background: #f5f5f5; color: #666; }
.btn-confirm { background: #667eea; color: white; }
