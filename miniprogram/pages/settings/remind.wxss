/* miniprogram/pages/settings/remind.wxss */
page { background: #f5f7fa; }
.container { padding: 30rpx; }

.menu-list {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child { border-bottom: none; }
.menu-item text { font-size: 28rpx; color: #333; }

.picker { font-size: 28rpx; color: #999; }

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 44rpx;
  color: white;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}
