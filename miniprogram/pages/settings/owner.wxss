/* miniprogram/pages/settings/owner.wxss */
page { background: #f5f7fa; }
.container { padding: 30rpx; }

.form {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.form-item:last-of-type { border-bottom: none; }

.label { width: 120rpx; font-size: 28rpx; color: #333; }
.input { flex: 1; font-size: 28rpx; }

.submit-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  border-radius: 44rpx;
  color: white;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}
