<!-- miniprogram/pages/settings/index.wxml -->
<view class="container">
  <!-- 用户信息 -->
  <view class="profile-card">
    <view class="avatar">{{userInfo.name ? userInfo.name[0] : (isTenant ? '租' : '管')}}</view>
    <view class="info">
      <text class="name">{{userInfo.name || userInfo.username || (isTenant ? '租客' : '管理员')}}</text>
      <text class="phone">{{userInfo.phone || (isTenant ? '租客' : '管理员')}}</text>
    </view>
  </view>

  <!-- 租客菜单 -->
  <view wx:if="{{isTenant}}" class="menu-list">
    <view class="menu-item" bindtap="goToRoleCheck">
      <text>我的权限</text>
      <text class="arrow">租客 ></text>
    </view>
    <view class="menu-item" bindtap="goToEdit">
      <text>个人信息</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- 管理员菜单 -->
  <view wx:else class="menu-list">
    <view class="menu-item" bindtap="goToRoleCheck">
      <text>我的权限</text>
      <text class="arrow">{{userInfo.role || 'admin'}} ></text>
    </view>
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goToAdminUsers">
      <text>管理员管理</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToEdit">
      <text>房东信息</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToRemind">
      <text>租金提醒</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" wx:if="{{isAdmin}}" bindtap="goToStaff">
      <text>维修人员管理</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToExport">
      <text>数据导出</text>
      <text class="arrow">></text>
    </view>
  </view>

  <view wx:if="{{!isTenant}}" class="menu-list">
    <view class="menu-item" bindtap="goToBackup">
      <text>数据备份</text>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <text>版本号</text>
      <text class="version">v1.0.0</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <button class="btn-logout" bindtap="onLogout">退出登录</button>
</view>