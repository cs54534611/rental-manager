<view class="container">
  <view class="logo">
    <text class="title">租房管理系统</text>
  </view>
  
  <view class="form">
    <!-- 登录类型选择 -->
    <view class="login-type">
      <radio-group bindchange="onLoginTypeChange">
        <label class="type-option">
          <radio value="admin" checked="{{loginType === 'admin'}}" />管理员
        </label>
        <label class="type-option">
          <radio value="tenant" checked="{{loginType === 'tenant'}}" />租客
        </label>
      </radio-group>
    </view>
    
    <view class="form-item">
      <input class="input" placeholder="{{loginType === 'tenant' ? '请输入手机号' : '请输入用户名'}}" bindinput="onUsernameInput" value="{{username}}" />
    </view>
    <view class="form-item">
      <input class="input" password placeholder="请输入密码" bindinput="onPasswordInput" value="{{password}}" />
    </view>
    <button class="btn-login" bindtap="onLogin" loading="{{loading}}">{{loading ? '登录中...' : '登录'}}</button>
  </view>
</view>
