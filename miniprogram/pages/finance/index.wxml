<!--miniprogram/pages/finance/index.wxml-->
<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-cards">
    <view class="card">
      <text class="label">本月收入</text>
      <text class="value">¥{{stats.monthIncome || 0}}</text>
    </view>
    <view class="card">
      <text class="label">待收金额</text>
      <text class="value warning">¥{{stats.pendingAmount || 0}}</text>
    </view>
    <view class="card">
      <text class="label">总收入</text>
      <text class="value success">¥{{stats.totalIncome || 0}}</text>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section">
    <view class="section-title">快捷操作</view>
    <view class="quick-actions">
      <view class="action-item" bindtap="goToPayments">
        <view class="icon-box pay">付</view>
        <text>支付记录</text>
      </view>
      <view class="action-item" bindtap="goToMeter">
        <view class="icon-box meter">表</view>
        <text>抄表记录</text>
      </view>
      <view class="action-item" bindtap="goToCheckout">
        <view class="icon-box checkout">退</view>
        <text>退房检查</text>
      </view>
      <view class="action-item" bindtap="goToStats">
        <view class="icon-box stats">图</view>
        <text>数据统计</text>
      </view>
    </view>
  </view>

  <!-- 支付方式统计 -->
  <view class="section" wx:if="{{stats.channelStats && stats.channelStats.length > 0}}">
    <view class="section-title">支付方式</view>
    <view class="channel-list">
      <view class="channel-item" wx:for="{{stats.channelStats}}" wx:key="channel">
        <text class="channel-name">{{item.channel}}</text>
        <text class="channel-count">{{item.count}}笔</text>
        <text class="channel-amount">¥{{item.amount}}</text>
      </view>
    </view>
  </view>

  <!-- 最近收入趋势 -->
  <view class="section" wx:if="{{stats.trend && stats.trend.length > 0}}">
    <view class="section-title">收入趋势（最近30天）</view>
    <view class="trend-chart">
      <view class="trend-item" wx:for="{{stats.trend}}" wx:key="date">
        <view class="trend-bar" style="height: {{item.amount / maxTrend * 100}}rpx"></view>
        <text class="trend-date">{{item.date}}</text>
      </view>
    </view>
  </view>
</view>
