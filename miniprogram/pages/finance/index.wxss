/* miniprogram/pages/finance/index.wxss */
.container {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;

  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.stats-cards {

  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;

}

.card {

  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 0 10rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);

}

.card .label {

  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;

}

.card .value {

  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;

}

.card .value.warning {

  color: #ff9800;

}

.card .value.success {

  color: #4caf50;

}

.section {

  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);

}

.section-title {

  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;

}

.quick-actions {

  display: flex;
  justify-content: space-around;

}

.action-item {

  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;

}

.action-item .icon-box {

  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;

}

.action-item .icon-box.pay {

  background: linear-gradient(135deg, #07c160, #06ad56);

}

.action-item .icon-box.meter {

  background: linear-gradient(135deg, #1989fa, #096dd9);

}

.action-item .icon-box.checkout {

  background: linear-gradient(135deg, #fa8c16, #fa7d00);

}

.action-item .icon-box.stats {

  background: linear-gradient(135deg, #667eea, #764ba2);

}

.action-item text {

  font-size: 24rpx;
  color: #666;

}

.channel-list {

  display: flex;
  flex-direction: column;
  gap: 20rpx;

}

.channel-item {

  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 8rpx;

}

.channel-name {

  font-size: 28rpx;
  color: #333;

}

.channel-count {

  font-size: 24rpx;
  color: #999;

}

.channel-amount {

  font-size: 28rpx;
  color: #4caf50;
  font-weight: bold;

}

.trend-chart {

  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  height: 200rpx;
  padding-top: 20rpx;

}

.trend-item {

  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;

}

.trend-bar {

  width: 30rpx;
  background: linear-gradient(to top, #667eea, #764ba2);
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;

}

.trend-date {

  font-size: 20rpx;
  color: #999;
  margin-top: 10rpx;
  transform: scale(0.8);

}
